---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_SOCIAL_IMAGE, ORGANIZATION, PERSON, SITE_DESCRIPTION, SITE_NAME, SITE_URL } from '../lib/site';
import { buildBreadcrumbSchema, type BreadcrumbItem } from '../lib/schema';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
  breadcrumbs?: BreadcrumbItem[];
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = DEFAULT_SOCIAL_IMAGE,
  type = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  section,
  tags = [],
  breadcrumbs = [],
  schema = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL);
const fullTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
const socialImage = new URL(image, Astro.site ?? SITE_URL).toString();
const pageSchemas = Array.isArray(schema) ? schema : [schema];
const schemas = breadcrumbs.length > 0 ? [...pageSchemas, buildBreadcrumbSchema(breadcrumbs)] : pageSchemas;

const siteSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: ORGANIZATION.name,
    legalName: ORGANIZATION.legalName,
    url: ORGANIZATION.url,
    email: ORGANIZATION.email,
    sameAs: ORGANIZATION.sameAs,
    publishingPrinciples: ORGANIZATION.publishingPrinciples,
    founder: {
      '@type': 'Person',
      name: PERSON.name,
      url: PERSON.url,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: PERSON.name,
    givenName: PERSON.givenName,
    familyName: PERSON.familyName,
    url: PERSON.url,
    jobTitle: PERSON.jobTitle,
    description: PERSON.description,
    worksFor: {
      '@type': 'Organization',
      name: ORGANIZATION.name,
      url: ORGANIZATION.url,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_NAME,
    url: SITE_URL,
    description: SITE_DESCRIPTION,
    inLanguage: 'en',
    creator: {
      '@type': 'Person',
      name: PERSON.name,
      url: PERSON.url,
    },
    publisher: {
      '@type': 'Organization',
      name: ORGANIZATION.name,
      url: ORGANIZATION.url,
    },
    publishingPrinciples: ORGANIZATION.publishingPrinciples,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="vojFvLUW3NcjO5FdjCejc-0X-g6SbuJtPVZ-RXw-3kQ" />
    <meta name="author" content={PERSON.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" />
    </noscript>
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {section && <meta property="article:section" content={section} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="pinterest-rich-pin" content="true" />
    <meta name="p:domain_verify" content="314871b4371c8fe024738a356a2a84ce" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="sitemap" href="/sitemap.xml" />

    {siteSchemas.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    {schemas.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
