---
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '@fontsource-variable/fraunces/full-italic.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getResponsiveImageMeta } from '../lib/images';
import { DEFAULT_SOCIAL_IMAGE, ORGANIZATION, PERSON, SITE_DESCRIPTION, SITE_LANGUAGE, SITE_LOGO, SITE_NAME, SITE_URL } from '../lib/site';
import { buildBreadcrumbSchema, type BreadcrumbItem } from '../lib/schema';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: string;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
  breadcrumbs?: BreadcrumbItem[];
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  resourceHints?: Array<{
    rel: string;
    href: string;
    as?: string;
    type?: string;
    imagesrcset?: string;
    imagesizes?: string;
    crossorigin?: string;
  }>;
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = DEFAULT_SOCIAL_IMAGE,
  imageAlt,
  type = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  section,
  tags = [],
  breadcrumbs = [],
  schema = [],
  resourceHints = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL);
const fullTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
const socialImage = new URL(image, Astro.site ?? SITE_URL).toString();
const socialImageMeta = getResponsiveImageMeta(image);
const pageSchemas = Array.isArray(schema) ? schema : [schema];
const schemas = breadcrumbs.length > 0 ? [...pageSchemas, buildBreadcrumbSchema(breadcrumbs)] : pageSchemas;
const robotsContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const siteSchemas = [
  {
    '@context': 'https://schema.org',
    '@id': `${SITE_URL}#organization`,
    '@type': 'Organization',
    name: ORGANIZATION.name,
    legalName: ORGANIZATION.legalName,
    url: ORGANIZATION.url,
    email: ORGANIZATION.email,
    logo: {
      '@type': 'ImageObject',
      url: ORGANIZATION.logo,
    },
    sameAs: ORGANIZATION.sameAs,
    publishingPrinciples: ORGANIZATION.publishingPrinciples,
    founder: {
      '@type': 'Person',
      name: PERSON.name,
      url: PERSON.url,
    },
  },
  {
    '@context': 'https://schema.org',
    '@id': `${PERSON.url}#person`,
    '@type': 'Person',
    name: PERSON.name,
    givenName: PERSON.givenName,
    familyName: PERSON.familyName,
    url: PERSON.url,
    jobTitle: PERSON.jobTitle,
    description: PERSON.description,
    worksFor: {
      '@type': 'Organization',
      name: ORGANIZATION.name,
      url: ORGANIZATION.url,
    },
  },
  {
    '@context': 'https://schema.org',
    '@id': `${SITE_URL}#website`,
    '@type': 'WebSite',
    name: SITE_NAME,
    url: SITE_URL,
    description: SITE_DESCRIPTION,
    inLanguage: SITE_LANGUAGE,
    creator: {
      '@type': 'Person',
      name: PERSON.name,
      url: PERSON.url,
    },
    publisher: {
      '@type': 'Organization',
      name: ORGANIZATION.name,
      url: ORGANIZATION.url,
    },
    publishingPrinciples: ORGANIZATION.publishingPrinciples,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="vojFvLUW3NcjO5FdjCejc-0X-g6SbuJtPVZ-RXw-3kQ" />
    <meta name="author" content={PERSON.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    {resourceHints.map((hint) => <link {...hint} />)}
    <meta name="robots" content={robotsContent} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    {imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    {socialImageMeta && <meta property="og:image:width" content={String(socialImageMeta.width)} />}
    {socialImageMeta && <meta property="og:image:height" content={String(socialImageMeta.height)} />}
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {section && <meta property="article:section" content={section} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="pinterest-rich-pin" content="true" />
    <meta name="p:domain_verify" content="314871b4371c8fe024738a356a2a84ce" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}

    <link rel="sitemap" href="/sitemap.xml" />

    {siteSchemas.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    {schemas.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
