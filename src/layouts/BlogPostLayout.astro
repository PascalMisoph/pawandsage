---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import EmailCapture from '../components/EmailCapture.astro';
import CatPlayCTA from '../components/CatPlayCTA.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { buildImageObject, buildImagePreloadHint } from '../lib/images';
import { buildFAQPageSchema } from '../lib/schema';
import { ORGANIZATION, PERSON, SITE_LANGUAGE, SITE_URL } from '../lib/site';

export interface RelatedPost {
  href: string;
  title: string;
}

export interface ClusterPostLink extends RelatedPost {
  current?: boolean;
}

export interface ClusterContext {
  title: string;
  hubHref: string;
  hubTitle: string;
  featuredHref: string;
  featuredTitle: string;
  clusterPosts: ClusterPostLink[];
  previousPost?: RelatedPost | null;
  nextPost?: RelatedPost | null;
}

const { frontmatter, relatedPosts = [] } = Astro.props as {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    category: 'behavior' | 'enrichment' | 'new-cat';
    readTime?: string;
    heroImage?: string;
    heroAlt?: string;
    tags?: string[];
    sources?: { title: string; url: string; publisher?: string }[];
    faq?: { question: string; answer: string }[];
  };
  relatedPosts?: RelatedPost[];
  clusterContext?: ClusterContext;
};

const { clusterContext } = Astro.props as { clusterContext?: ClusterContext };
const { title, description, pubDate, updatedDate, category, readTime, heroImage, heroAlt = '', tags = [], sources = [], faq = [] } = frontmatter;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate
  ? new Date(updatedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const categoryLabels = {
  behavior: 'Behavior',
  enrichment: 'Enrichment',
  'new-cat': 'New Cat',
};

const leadMagnetByCategory = {
  behavior: {
    title: 'The Cat Behavior Decoder',
    description: 'A free PDF with the body language cues and behavior patterns worth noticing first.',
  },
  enrichment: {
    title: 'The Indoor Cat Enrichment Starter Plan',
    description: 'A simple download with play, food puzzle, and routine ideas you can use this week.',
  },
  'new-cat': {
    title: 'The New Kitten First Week Checklist',
    description: 'A starter checklist covering litter, food, carrier, setup, and the first routines that matter most.',
  },
} satisfies Record<string, { title: string; description: string }>;

const showCatPlay = category === 'behavior' || category === 'enrichment';
const canonical = `${SITE_URL}${Astro.url.pathname}`;
const heroImageObject = buildImageObject(heroImage);
const heroResourceHint = heroImage ? buildImagePreloadHint(heroImage, '(min-width: 1132px) 1100px, calc(100vw - 3rem)') : null;
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Journal', path: '/blog' },
  { name: categoryLabels[category], path: `/categories/${category}` },
  { name: title, path: Astro.url.pathname },
];

const articleSchema = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    image: heroImageObject
      ? {
          ...heroImageObject,
          url: `${SITE_URL}${heroImage}`,
        }
      : undefined,
    mainEntityOfPage: canonical,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    articleSection: categoryLabels[category],
    inLanguage: SITE_LANGUAGE,
    isPartOf: {
      '@id': `${SITE_URL}#website`,
    },
    keywords: tags.join(', '),
    author: {
      '@type': 'Person',
      name: PERSON.name,
      url: PERSON.url,
      jobTitle: PERSON.jobTitle,
    },
    publisher: {
      '@type': 'Organization',
      name: ORGANIZATION.name,
      url: ORGANIZATION.url,
      logo: {
        '@type': 'ImageObject',
        url: ORGANIZATION.logo,
      },
    },
    citation: sources.length > 0 ? sources.map((source) => source.url) : undefined,
    isAccessibleForFree: true,
  };

const schema = [
  articleSchema,
  ...(faq.length > 0 ? [buildFAQPageSchema(faq)] : []),
];
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  image={heroImage}
  imageAlt={heroAlt}
  publishedTime={pubDate.toISOString()}
  modifiedTime={(updatedDate ?? pubDate).toISOString()}
  section={categoryLabels[category]}
  tags={tags}
  breadcrumbs={breadcrumbs}
  schema={schema}
  resourceHints={heroResourceHint ? [heroResourceHint] : []}
>
  <article>
    <div class="container-narrow">
      <Breadcrumbs
        items={[
          { name: 'Home', href: '/' },
          { name: 'Journal', href: '/blog' },
          { name: categoryLabels[category], href: `/categories/${category}` },
          { name: title },
        ]}
      />
    </div>

    <header class="post-header">
      <div class="container-narrow">
        <div class="post-meta">
          <a href={`/categories/${category}`} class="post-category">
            {categoryLabels[category]}
          </a>
          <time class="post-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
          {readTime && <span class="post-readtime">· {readTime}</span>}
          {formattedUpdatedDate && (
            <span class="post-updated">Updated {formattedUpdatedDate}</span>
          )}
          {sources.length > 0 && <span class="post-sources">{sources.length} sources reviewed</span>}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
      </div>
    </header>

    {heroImage && (
      <div class="post-hero">
        <ResponsiveImage
          src={heroImage}
          alt={heroAlt}
          sizes="(min-width: 1132px) 1100px, calc(100vw - 3rem)"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          pictureClass="post-hero-picture"
          imgClass="post-hero-image"
        />
      </div>
    )}

    <div class="container-narrow">
      <div class="author-box">
        <p>
          Written by <a href="/about">Pascal Misoph</a>. Read our <a href="/editorial-policy">editorial policy</a> for how articles are researched, updated, and reviewed.
        </p>
        <p class="author-box-meta">
          Published {formattedDate}{formattedUpdatedDate ? ` · Updated ${formattedUpdatedDate}` : ''}{sources.length > 0 ? ` · ${sources.length} source${sources.length === 1 ? '' : 's'} linked below` : ''}.
        </p>
      </div>

      <div class="disclosure">
        This post contains affiliate links. As an Amazon Associate, I earn from qualifying purchases at no extra cost to you. I only recommend products I would use for my own cat.
      </div>

      {clusterContext && (
        <aside class="cluster-map">
          <span class="eyebrow">Topic hub</span>
          <h2>Part of the {clusterContext.title} cluster.</h2>
          <p>
            Start with the <a href={clusterContext.hubHref}>{clusterContext.hubTitle}</a> or the
            foundational guide <a href={clusterContext.featuredHref}>{clusterContext.featuredTitle}</a>, then work through the related pages below.
          </p>
          <ul class="cluster-links">
            {clusterContext.clusterPosts.map((post) => (
              <li class:list={{ current: post.current }}>
                {post.current ? (
                  <span aria-current="page">{post.title}</span>
                ) : (
                  <a href={post.href}>{post.title}</a>
                )}
              </li>
            ))}
          </ul>
          {(clusterContext.previousPost || clusterContext.nextPost) && (
            <div class="cluster-nav">
              {clusterContext.previousPost ? (
                <a href={clusterContext.previousPost.href}>Previous: {clusterContext.previousPost.title}</a>
              ) : (
                <span />
              )}
              {clusterContext.nextPost ? (
                <a href={clusterContext.nextPost.href}>Next: {clusterContext.nextPost.title}</a>
              ) : (
                <span />
              )}
            </div>
          )}
        </aside>
      )}

      <div class="prose">
        <slot />
      </div>

      {sources.length > 0 && (
        <section class="sources">
          <h2>Sources</h2>
          <ul>
            {sources.map((source) => (
              <li>
                <a href={source.url} target="_blank" rel="noopener noreferrer">{source.title}</a>
                {source.publisher && <span> ({source.publisher})</span>}
              </li>
            ))}
          </ul>
        </section>
      )}

      {faq.length > 0 && (
        <section class="faq-section" aria-labelledby="article-faq-title">
          <span class="eyebrow">FAQ</span>
          <h2 id="article-faq-title">Common questions</h2>
          <div class="faq-list">
            {faq.map((item) => (
              <details>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      {relatedPosts.length > 0 && (
        <aside class="related-posts">
          <span class="eyebrow">Read next</span>
          <h2>Continue through the cluster.</h2>
          <ul>
            {relatedPosts.map((post) => (
              <li><a href={post.href}>{post.title}</a></li>
            ))}
          </ul>
        </aside>
      )}

      <EmailCapture
        title={leadMagnetByCategory[category].title}
        description={leadMagnetByCategory[category].description}
      />

      {showCatPlay && <CatPlayCTA />}
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding: 2rem 0 3rem;
    text-align: center;
  }
  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--ink-soft);
    flex-wrap: wrap;
  }
  .post-category {
    color: var(--terra-700);
    font-weight: 600;
    text-decoration: none;
  }
  .post-title {
    margin-bottom: 1.25rem;
  }
  .post-description {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.25rem;
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 580px;
    margin: 0 auto;
  }
  .post-hero {
    max-width: 1100px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }
  .post-hero :global(.post-hero-picture) {
    display: block;
    width: 100%;
  }
  .post-hero :global(.post-hero-image) {
    width: 100%;
    height: auto;
    border-radius: 12px;
    aspect-ratio: 16/9;
    object-fit: cover;
    object-position: center;
  }
  .author-box {
    padding: 1rem 1.25rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--cream-200);
    margin-bottom: 1.5rem;
  }
  .author-box p {
    margin: 0;
    color: var(--ink-soft);
  }
  .author-box-meta {
    margin-top: 0.5rem !important;
    font-size: 0.9rem;
  }
  .prose {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ink);
  }
  .prose :global(h2) {
    margin-top: 3rem;
  }
  .prose :global(h3) {
    margin-top: 2.5rem;
  }
  .cluster-map,
  .sources,
  .faq-section,
  .related-posts {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .cluster-map p {
    color: var(--ink-soft);
    max-width: 60ch;
  }
  .cluster-links {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }
  .cluster-links li {
    padding: 0.875rem 1rem;
    background: var(--cream-200);
    border: 1px solid var(--line);
    border-radius: 10px;
  }
  .cluster-links li.current {
    background: var(--sage-50);
    border-color: var(--sage-300);
  }
  .cluster-links li.current span {
    color: var(--sage-900);
    font-weight: 600;
  }
  .cluster-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .cluster-nav a,
  .cluster-nav span {
    display: block;
    padding: 0.875rem 1rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--cream-100);
    min-height: 100%;
  }
  .sources ul,
  .related-posts ul {
    margin-top: 1rem;
  }
  .faq-list {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }
  .faq-list details {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--cream-200);
    padding: 1rem 1.125rem;
  }
  .faq-list summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--sage-900);
  }
  .faq-list p {
    margin: 0.75rem 0 0;
    color: var(--ink-soft);
  }
  @media (max-width: 700px) {
    .cluster-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
