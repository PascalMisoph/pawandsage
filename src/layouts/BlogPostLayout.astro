---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import EmailCapture from '../components/EmailCapture.astro';
import CatPlayCTA from '../components/CatPlayCTA.astro';
import { ORGANIZATION, PERSON, SITE_URL } from '../lib/site';

export interface RelatedPost {
  href: string;
  title: string;
}

const { frontmatter, relatedPosts = [] } = Astro.props as {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    category: 'behavior' | 'enrichment' | 'new-cat';
    readTime?: string;
    heroImage?: string;
    heroAlt?: string;
    tags?: string[];
    sources?: { title: string; url: string; publisher?: string }[];
  };
  relatedPosts?: RelatedPost[];
};

const { title, description, pubDate, updatedDate, category, readTime, heroImage, heroAlt = '', tags = [], sources = [] } = frontmatter;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate
  ? new Date(updatedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const categoryLabels = {
  behavior: 'Behavior',
  enrichment: 'Enrichment',
  'new-cat': 'New Cat',
};

const leadMagnetByCategory = {
  behavior: {
    title: 'The Cat Behavior Decoder',
    description: 'A free PDF with the body language cues and behavior patterns worth noticing first.',
  },
  enrichment: {
    title: 'The Indoor Cat Enrichment Starter Plan',
    description: 'A simple download with play, food puzzle, and routine ideas you can use this week.',
  },
  'new-cat': {
    title: 'The New Kitten First Week Checklist',
    description: 'A starter checklist covering litter, food, carrier, setup, and the first routines that matter most.',
  },
} satisfies Record<string, { title: string; description: string }>;

const showCatPlay = category === 'behavior' || category === 'enrichment';
const canonical = `${SITE_URL}${Astro.url.pathname}`;
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Journal', path: '/blog' },
  { name: categoryLabels[category], path: `/categories/${category}` },
  { name: title, path: Astro.url.pathname },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    image: heroImage ? `${SITE_URL}${heroImage}` : undefined,
    mainEntityOfPage: canonical,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    articleSection: categoryLabels[category],
    keywords: tags.join(', '),
    author: {
      '@type': 'Person',
      name: PERSON.name,
      url: PERSON.url,
      jobTitle: PERSON.jobTitle,
    },
    publisher: {
      '@type': 'Organization',
      name: ORGANIZATION.name,
      url: ORGANIZATION.url,
    },
    citation: sources.length > 0 ? sources.map((source) => source.url) : undefined,
  },
];
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  image={heroImage}
  publishedTime={pubDate.toISOString()}
  modifiedTime={(updatedDate ?? pubDate).toISOString()}
  section={categoryLabels[category]}
  tags={tags}
  breadcrumbs={breadcrumbs}
  schema={schema}
>
  <article>
    <div class="container-narrow">
      <Breadcrumbs
        items={[
          { name: 'Home', href: '/' },
          { name: 'Journal', href: '/blog' },
          { name: categoryLabels[category], href: `/categories/${category}` },
          { name: title },
        ]}
      />
    </div>

    <header class="post-header">
      <div class="container-narrow">
        <div class="post-meta">
          <a href={`/categories/${category}`} class="post-category">
            {categoryLabels[category]}
          </a>
          <time class="post-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
          {readTime && <span class="post-readtime">· {readTime}</span>}
          {formattedUpdatedDate && (
            <span class="post-updated">Updated {formattedUpdatedDate}</span>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
      </div>
    </header>

    {heroImage && (
      <div class="post-hero">
        <img
          src={heroImage}
          alt={heroAlt}
          width="1200"
          height="675"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    )}

    <div class="container-narrow">
      <div class="author-box">
        <p>
          Written by <a href="/about">Pascal Misoph</a>. Read our <a href="/editorial-policy">editorial policy</a> for how articles are researched, updated, and reviewed.
        </p>
      </div>

      <div class="disclosure">
        This post contains affiliate links. As an Amazon Associate, I earn from qualifying purchases at no extra cost to you. I only recommend products I would use for my own cat.
      </div>

      <div class="prose">
        <slot />
      </div>

      {sources.length > 0 && (
        <section class="sources">
          <h2>Sources</h2>
          <ul>
            {sources.map((source) => (
              <li>
                <a href={source.url} target="_blank" rel="noopener noreferrer">{source.title}</a>
                {source.publisher && <span> ({source.publisher})</span>}
              </li>
            ))}
          </ul>
        </section>
      )}

      {relatedPosts.length > 0 && (
        <aside class="related-posts">
          <span class="eyebrow">Read next</span>
          <h2>Continue through the cluster.</h2>
          <ul>
            {relatedPosts.map((post) => (
              <li><a href={post.href}>{post.title}</a></li>
            ))}
          </ul>
        </aside>
      )}

      <EmailCapture
        title={leadMagnetByCategory[category].title}
        description={leadMagnetByCategory[category].description}
      />

      {showCatPlay && <CatPlayCTA />}
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding: 2rem 0 3rem;
    text-align: center;
  }
  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--ink-soft);
    flex-wrap: wrap;
  }
  .post-category {
    color: var(--terra-700);
    font-weight: 600;
    text-decoration: none;
  }
  .post-title {
    margin-bottom: 1.25rem;
  }
  .post-description {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.25rem;
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 580px;
    margin: 0 auto;
  }
  .post-hero {
    max-width: 1100px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }
  .post-hero img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    aspect-ratio: 16/9;
    object-fit: cover;
  }
  .author-box {
    padding: 1rem 1.25rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--cream-200);
    margin-bottom: 1.5rem;
  }
  .author-box p {
    margin: 0;
    color: var(--ink-soft);
  }
  .prose {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ink);
  }
  .prose :global(h2) {
    margin-top: 3rem;
  }
  .prose :global(h3) {
    margin-top: 2.5rem;
  }
  .sources,
  .related-posts {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .sources ul,
  .related-posts ul {
    margin-top: 1rem;
  }
</style>
