---
import BaseLayout from './BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
import CatPlayCTA from '../components/CatPlayCTA.astro';

const { frontmatter } = Astro.props;
const { title, description, pubDate, category, readTime, heroImage } = frontmatter;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabels = {
  'behavior': 'Behavior',
  'enrichment': 'Enrichment',
  'new-cat': 'New Cat',
  'health': 'Health',
};
---

<BaseLayout title={title} description={description} type="article" image={heroImage}>
  <article>
    <header class="post-header">
      <div class="container-narrow">
        <div class="post-meta">
          <a href={`/categories/${category}`} class="post-category">
            {categoryLabels[category]}
          </a>
          <span class="post-date">{formattedDate}</span>
          {readTime && <span class="post-readtime">· {readTime}</span>}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
      </div>
    </header>

    {heroImage && (
      <div class="post-hero">
        <img src={heroImage} alt={title} />
      </div>
    )}

    <div class="container-narrow">
      <div class="disclosure">
        This post contains affiliate links. As an Amazon Associate and Chewy affiliate, I earn from qualifying purchases at no extra cost to you. I only recommend products I would use for my own cat.
      </div>

      <div class="prose">
        <slot />
      </div>

      <EmailCapture />

      <CatPlayCTA />
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding: 4rem 0 3rem;
    text-align: center;
  }
  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--ink-soft);
  }
  .post-category {
    color: var(--terra-700);
    font-weight: 600;
    text-decoration: none;
  }
  .post-category:hover {
    color: var(--terra-500);
  }
  .post-title {
    margin-bottom: 1.25rem;
  }
  .post-description {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.25rem;
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 580px;
    margin: 0 auto;
  }
  .post-hero {
    max-width: 1100px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }
  .post-hero img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    aspect-ratio: 16/9;
    object-fit: cover;
  }
  .prose {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ink);
  }
  .prose :global(h2) {
    margin-top: 3rem;
  }
  .prose :global(h3) {
    margin-top: 2.5rem;
  }
</style>
