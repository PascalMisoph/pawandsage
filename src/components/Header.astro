---
const navItems = [
  { href: '/blog', label: 'Journal' },
  { href: '/categories/behavior', label: 'Behavior' },
  { href: '/categories/enrichment', label: 'Enrichment' },
  { href: '/categories/new-cat', label: 'New Cat' },
  { href: '/categories/health', label: 'Health' },
  { href: '/about', label: 'About' },
];

const isHome = Astro.url.pathname === '/';
---

<header class={isHome ? 'home-header' : undefined}>
  <div class="container header-inner">
    <a href="/" class="logo">
      paw <span class="and">and</span> sage
    </a>
    <nav id="site-nav">
      <ul>
        {navItems.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <button
      class="menu-toggle"
      type="button"
      aria-label="Toggle menu"
      aria-controls="site-nav"
      aria-expanded="false"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--line);
    background: var(--cream-100);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
    background: rgba(250, 246, 239, 0.92);
  }
  header.home-header {
    position: absolute;
    inset: 0 0 auto 0;
    border-bottom: none;
    background: transparent;
    backdrop-filter: none;
  }
  header.home-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(250, 246, 239, 0.9) 0%,
      rgba(250, 246, 239, 0.76) 34%,
      rgba(250, 246, 239, 0.28) 66%,
      rgba(250, 246, 239, 0.08) 100%
    );
    pointer-events: none;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    position: relative;
    z-index: 1;
  }
  .logo {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    color: var(--sage-900);
    text-decoration: none;
    font-weight: 400;
    letter-spacing: -0.5px;
  }
  .logo .and {
    font-style: italic;
    font-weight: 300;
    color: var(--terra-500);
  }
  nav ul {
    display: flex;
    gap: 1.75rem;
    list-style: none;
  }
  nav a {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }
  nav a:hover {
    color: var(--sage-900);
  }
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .menu-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--sage-900);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  @media (max-width: 768px) {
    header.home-header::before {
      background: rgba(250, 246, 239, 0.78);
      backdrop-filter: blur(8px);
    }
    nav {
      display: block;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 1.25rem;
      right: 1.25rem;
      padding: 0.85rem 1rem;
      border: 1px solid rgba(90, 84, 78, 0.12);
      border-radius: 1rem;
      background: rgba(250, 246, 239, 0.96);
      backdrop-filter: blur(12px);
      box-shadow: 0 18px 40px rgba(42, 39, 36, 0.1);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-0.35rem);
      transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    }
    nav ul {
      flex-direction: column;
      gap: 0.25rem;
    }
    nav a {
      display: block;
      padding: 0.7rem 0.25rem;
    }
    header.menu-open nav {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    header.menu-open .menu-toggle span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }
    header.menu-open .menu-toggle span:nth-child(2) {
      opacity: 0;
    }
    header.menu-open .menu-toggle span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }
    .menu-toggle { display: flex; }
  }
</style>

<script>
  const header = document.querySelector('header');
  const toggle = header?.querySelector('.menu-toggle');
  const nav = header?.querySelector('#site-nav');
  const navLinks = nav?.querySelectorAll('a') ?? [];

  const closeMenu = () => {
    if (!header || !toggle) return;
    header.classList.remove('menu-open');
    toggle.setAttribute('aria-expanded', 'false');
  };

  toggle?.addEventListener('click', () => {
    if (!header || !toggle) return;
    const isOpen = header.classList.toggle('menu-open');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  navLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) {
      closeMenu();
    }
  });

  document.addEventListener('click', (event) => {
    if (!header || !toggle) return;
    if (!header.classList.contains('menu-open')) return;
    const target = event.target;
    if (target instanceof Node && !header.contains(target)) {
      closeMenu();
    }
  });
</script>
