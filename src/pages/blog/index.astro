---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Journal" description="Calm, considered writing about cats and the people who live with them.">
  <section class="page-header">
    <div class="container-narrow">
      <span class="eyebrow">The Journal</span>
      <h1>Everything we've written.</h1>
      <p class="page-description">
        Articles on cat behavior, indoor enrichment, new cat care, and health signals — written for people who want to understand, not just entertain.
      </p>
    </div>
  </section>

  <section class="posts-section">
    <div class="container">
      {sortedPosts.length > 0 ? (
        <div class="posts-grid">
          {sortedPosts.map(post => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              readTime={post.data.readTime}
              image={post.data.heroImage}
            />
          ))}
        </div>
      ) : (
        <p class="empty">No posts yet — coming soon.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 5rem 0 3rem;
    text-align: center;
  }
  .page-header .eyebrow {
    display: block;
    margin-bottom: 1rem;
  }
  .page-description {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.15rem;
    color: var(--ink-soft);
    max-width: 560px;
    margin: 1rem auto 0;
    line-height: 1.5;
  }
  .posts-section {
    padding: 2rem 0 5rem;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .empty {
    text-align: center;
    color: var(--ink-soft);
    padding: 3rem 0;
  }
  @media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
