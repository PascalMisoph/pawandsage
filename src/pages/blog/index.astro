---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { buildCollectionPageSchema } from '../../lib/schema';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Journal', path: '/blog' },
];
const schema = buildCollectionPageSchema({
  name: 'Paw & Sage Journal',
  description: 'Calm, considered writing about cats and the people who live with them.',
  path: '/blog',
  about: 'Cat behavior, indoor enrichment, and new cat care',
  significantLinks: ['/categories/behavior', '/categories/enrichment', '/categories/new-cat'],
  hasPart: sortedPosts.map((post) => `/blog/${post.id}`),
});
---

<BaseLayout
  title="Journal"
  description="Calm, considered writing about cats and the people who live with them."
  breadcrumbs={breadcrumbs}
  schema={schema}
>
  <section class="page-header">
    <div class="container-narrow">
      <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Journal' }]} />
      <span class="eyebrow">The Journal</span>
      <h1>Everything we've written.</h1>
      <p class="page-description">
        Articles on cat behavior, indoor enrichment, and new cat care for people who want to understand, not just entertain.
      </p>
      <p class="page-intro">
        Start with the cluster that best matches your current problem, then move sideways through related guides to build a clearer picture.
      </p>
    </div>
  </section>

  <section class="cluster-links">
    <div class="container">
      <div class="cluster-grid">
        <a href="/categories/behavior" class="cluster-card">
          <span class="eyebrow">Cluster</span>
          <h2>Behavior</h2>
          <p>Decode staring, night waking, attention habits, and the patterns behind common cat behavior questions.</p>
        </a>
        <a href="/categories/enrichment" class="cluster-card">
          <span class="eyebrow">Cluster</span>
          <h2>Enrichment</h2>
          <p>Build a richer indoor routine with play structure, boredom prevention, and practical product choices.</p>
        </a>
        <a href="/categories/new-cat" class="cluster-card">
          <span class="eyebrow">Cluster</span>
          <h2>New Cat</h2>
          <p>Focus on first week setup, essential purchases, and the calm routines that help a new cat settle in.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="posts-section">
    <div class="container">
      {sortedPosts.length > 0 ? (
        <div class="posts-grid">
          {sortedPosts.map((post) => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              readTime={post.data.readTime}
              image={post.data.heroImage}
              imageAlt={post.data.heroAlt}
            />
          ))}
        </div>
      ) : (
        <p class="empty">No posts yet.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 5rem 0 3rem;
    text-align: center;
  }
  .page-header .eyebrow {
    display: block;
    margin-bottom: 1rem;
  }
  .page-description,
  .page-intro {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    color: var(--ink-soft);
    max-width: 620px;
    line-height: 1.5;
    margin: 1rem auto 0;
  }
  .page-description { font-size: 1.15rem; }
  .page-intro { font-size: 1rem; }
  .cluster-links { padding: 0 0 2rem; }
  .cluster-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .cluster-card {
    background: var(--cream-200);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
  }
  .cluster-card h2 {
    margin: 0.75rem 0 0.5rem;
  }
  .cluster-card p {
    margin: 0;
    color: var(--ink-soft);
  }
  .posts-section {
    padding: 2rem 0 5rem;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .empty {
    text-align: center;
    color: var(--ink-soft);
    padding: 3rem 0;
  }
  @media (max-width: 900px) {
    .cluster-grid,
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .cluster-grid,
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
