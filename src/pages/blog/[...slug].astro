---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { clusterConfigBySlug } from '../../lib/clusters';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const postMap = new Map(posts.map((post) => [post.id, post]));

  return posts.map((post) => {
    const cluster = clusterConfigBySlug[post.data.category];
    const orderedClusterPosts = cluster.orderedPosts
      .map((slug) => postMap.get(slug))
      .filter(Boolean);
    const currentIndex = orderedClusterPosts.findIndex((candidate) => candidate?.id === post.id);
    const previousPost = currentIndex > 0 ? orderedClusterPosts[currentIndex - 1] : null;
    const nextPost = currentIndex >= 0 ? orderedClusterPosts[currentIndex + 1] : null;
    const clusterPosts = orderedClusterPosts.map((candidate) => ({
      href: `/blog/${candidate!.id}`,
      title: candidate!.data.title,
      current: candidate!.id === post.id,
    }));
    const relatedPosts = posts
      .filter((candidate) => candidate.id !== post.id)
      .map((candidate) => {
        const sameCategoryScore = candidate.data.category === post.data.category ? 3 : 0;
        const sharedTags = (candidate.data.tags ?? []).filter((tag) => (post.data.tags ?? []).includes(tag)).length;
        return {
          href: `/blog/${candidate.id}`,
          title: candidate.data.title,
          score: sameCategoryScore + sharedTags,
        };
      })
      .sort((a, b) => b.score - a.score)
      .slice(0, 3)
      .map(({ href, title }) => ({ href, title }));

    return {
      params: { slug: post.id },
      props: {
        post,
        relatedPosts,
        clusterContext: {
          title: cluster.title,
          hubHref: `/categories/${cluster.slug}`,
          hubTitle: `${cluster.title} hub`,
          featuredHref: cluster.featured,
          featuredTitle: cluster.featuredTitle,
          clusterPosts,
          previousPost: previousPost
            ? { href: `/blog/${previousPost.id}`, title: previousPost.data.title }
            : null,
          nextPost: nextPost
            ? { href: `/blog/${nextPost.id}`, title: nextPost.data.title }
            : null,
        },
      },
    };
  });
}

const { post, relatedPosts, clusterContext } = Astro.props;
const { Content } = await render(post);
---

<BlogPostLayout frontmatter={post.data} relatedPosts={relatedPosts} clusterContext={clusterContext}>
  <Content />
</BlogPostLayout>
