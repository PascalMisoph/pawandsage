---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const categories = [
    {
      slug: 'behavior',
      title: 'Behavior',
      description: 'What your cat is actually telling you, and how to listen.',
    },
    {
      slug: 'enrichment',
      title: 'Enrichment',
      description: 'Small changes that turn a flat indoor life into a rich one.',
    },
    {
      slug: 'new-cat',
      title: 'New Cat',
      description: 'Everything you wish someone had told you in the first week.',
    },
    {
      slug: 'health',
      title: 'Health',
      description: 'The subtle signals worth noticing — and when to call the vet.',
    },
  ];

  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  return categories.map(cat => ({
    params: { category: cat.slug },
    props: {
      category: cat,
      posts: allPosts
        .filter(post => post.data.category === cat.slug)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={category.title} description={category.description}>
  <section class="page-header">
    <div class="container-narrow">
      <span class="eyebrow">Category</span>
      <h1>{category.title}</h1>
      <p class="page-description">{category.description}</p>
    </div>
  </section>

  <section class="posts-section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map(post => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              readTime={post.data.readTime}
              image={post.data.heroImage}
            />
          ))}
        </div>
      ) : (
        <p class="empty">No posts in this category yet — coming soon.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { padding: 5rem 0 3rem; text-align: center; }
  .page-header .eyebrow { display: block; margin-bottom: 1rem; }
  .page-description {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.15rem;
    color: var(--ink-soft);
    max-width: 560px;
    margin: 1rem auto 0;
    line-height: 1.5;
  }
  .posts-section { padding: 2rem 0 5rem; }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .empty {
    text-align: center;
    color: var(--ink-soft);
    padding: 3rem 0;
  }
  @media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
