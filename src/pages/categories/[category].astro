---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostCard from '../../components/PostCard.astro';
import { clusterConfigs } from '../../lib/clusters';
import { buildCollectionPageSchema, buildFAQPageSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  return clusterConfigs.map((category) => ({
    params: { category: category.slug },
    props: {
      category,
      posts: allPosts
        .filter((post) => post.data.category === category.slug)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Journal', path: '/blog' },
  { name: category.title, path: `/categories/${category.slug}` },
];
const schema = [
  buildCollectionPageSchema({
    name: `${category.title} on Paw & Sage`,
    description: category.description,
    path: `/categories/${category.slug}`,
    about: `${category.title} advice for cat owners`,
    significantLinks: category.nextReads.map((item) => item.href),
    hasPart: posts.map((post) => `/blog/${post.id}`),
  }),
  buildFAQPageSchema(category.faq),
];
---

<BaseLayout
  title={`${category.title} for cat owners`}
  description={category.description}
  breadcrumbs={breadcrumbs}
  schema={schema}
>
  <section class="page-header">
    <div class="container-narrow">
      <Breadcrumbs
        items={[
          { name: 'Home', href: '/' },
          { name: 'Journal', href: '/blog' },
          { name: category.title },
        ]}
      />
      <span class="eyebrow">Category</span>
      <h1>{category.title}</h1>
      <p class="page-description">{category.description}</p>
      <p class="hub-intro">{category.intro}</p>
    </div>
  </section>

  <section class="hub-section">
    <div class="container">
      <div class="hub-grid">
        <aside class="hub-card">
          <span class="eyebrow">{category.featuredLabel}</span>
          <h2><a href={category.featured}>{category.featuredTitle}</a></h2>
          <p>Use this as the first stop before branching into the rest of the cluster.</p>
        </aside>

        <aside class="hub-card">
          <span class="eyebrow">Next reads</span>
          <ul class="hub-links">
            {category.nextReads.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="posts-section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map((post) => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              readTime={post.data.readTime}
              image={post.data.heroImage}
              imageAlt={post.data.heroAlt}
            />
          ))}
        </div>
      ) : (
        <p class="empty">No posts in this category yet.</p>
      )}
    </div>
  </section>

  <section class="faq-section">
    <div class="container-narrow">
      <span class="eyebrow">FAQ</span>
      <h2>What this section covers.</h2>
      <div class="faq-list">
        {category.faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { padding: 5rem 0 2rem; text-align: center; }
  .page-header .eyebrow { display: block; margin-bottom: 1rem; }
  .page-description,
  .hub-intro {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 640px;
    margin: 1rem auto 0;
  }
  .page-description { font-size: 1.15rem; }
  .hub-intro { font-size: 1rem; }
  .hub-section { padding: 1rem 0 2rem; }
  .hub-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .hub-card {
    background: var(--cream-200);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1.75rem;
  }
  .hub-card h2 {
    margin: 0.75rem 0;
    font-size: 1.45rem;
  }
  .hub-card p,
  .hub-links {
    color: var(--ink-soft);
  }
  .hub-links {
    list-style: none;
    margin: 0;
  }
  .hub-links li + li {
    margin-top: 0.75rem;
  }
  .posts-section { padding: 2rem 0 4rem; }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .faq-section { padding: 0 0 5rem; }
  .faq-list details {
    border-top: 1px solid var(--line);
    padding: 1rem 0;
  }
  .faq-list summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--sage-900);
  }
  .faq-list p {
    margin: 0.75rem 0 0;
    color: var(--ink-soft);
  }
  .empty {
    text-align: center;
    color: var(--ink-soft);
    padding: 3rem 0;
  }
  @media (max-width: 900px) {
    .hub-grid,
    .posts-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .hub-grid,
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
