---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { buildCollectionPageSchema } from '../lib/schema';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Start Here', path: '/start-here' },
];
const schema = buildCollectionPageSchema({
  name: 'Start Here',
  description: 'The best first pages to read on Paw & Sage depending on what brought you here.',
  path: '/start-here',
  about: 'How to navigate Paw & Sage',
  significantLinks: ['/blog/new-kitten-checklist', '/blog/why-cat-stares-at-me', '/blog/indoor-cat-enrichment-ideas'],
  hasPart: [
    '/blog/new-kitten-checklist',
    '/blog/why-cat-stares-at-me',
    '/blog/indoor-cat-enrichment-ideas',
    '/blog/why-cat-wakes-you-3am',
    '/blog/why-cat-knocks-things-off-tables',
  ],
});
---

<BaseLayout
  title="Start here"
  description="New to paw and sage? Begin here."
  breadcrumbs={breadcrumbs}
  schema={schema}
>
  <section class="page-header">
    <div class="container-narrow">
      <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Start Here' }]} />
      <span class="eyebrow">Welcome</span>
      <h1>Start here.</h1>
      <p class="lede">If you are new to paw and sage, these are the best places to begin depending on what brought you here.</p>
    </div>
  </section>

  <section class="paths-section">
    <div class="container-narrow">
      <div class="path">
        <h2>I just got a new cat or kitten</h2>
        <p>Start with <a href="/blog/new-kitten-checklist">our complete kitten checklist</a>, then browse the <a href="/categories/new-cat">New Cat</a> section for first week questions and setup basics.</p>
      </div>

      <div class="path">
        <h2>My cat is doing something weird</h2>
        <p>Start with <a href="/blog/why-cat-stares-at-me">Why does my cat stare at me?</a> or go straight to <a href="/categories/behavior">Behavior</a> for the full cluster.</p>
      </div>

      <div class="path">
        <h2>My indoor cat seems bored</h2>
        <p>Start with <a href="/blog/indoor-cat-enrichment-ideas">20 indoor cat enrichment ideas</a>, then continue into <a href="/blog/best-interactive-cat-toys">interactive toys that actually work</a>.</p>
      </div>

      <div class="path">
        <h2>My cat keeps waking me up or knocking things over</h2>
        <p>Read <a href="/blog/why-cat-wakes-you-3am">why your cat wakes you up at 3 AM</a> and <a href="/blog/why-cat-knocks-things-off-tables">why cats knock things off tables</a> for the quickest fixes.</p>
      </div>

      <div class="email-section">
        <EmailCapture
          title="The Cat Behavior Decoder"
          description="A free PDF with the body language cues and behavior patterns worth noticing first."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { padding: 5rem 0 2rem; text-align: center; }
  .page-header .eyebrow { display: block; margin-bottom: 1rem; }
  .lede {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.15rem;
    color: var(--ink-soft);
    max-width: 560px;
    margin: 1rem auto 0;
    line-height: 1.5;
  }
  .paths-section { padding: 2rem 0 5rem; }
  .path {
    padding: 2rem 0;
    border-bottom: 1px solid var(--line);
  }
  .path:last-of-type { border-bottom: none; }
  .path h2 {
    font-size: 1.5rem;
    margin: 0 0 0.75rem;
  }
  .path p {
    color: var(--ink-soft);
    line-height: 1.7;
    margin: 0;
  }
  .email-section { margin-top: 3rem; }
</style>
