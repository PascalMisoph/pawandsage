---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { buildPageSchema } from '../lib/schema';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Affiliate Disclosure', path: '/disclosure' },
];

const schema = buildPageSchema({
  name: 'Affiliate Disclosure',
  description: 'How Paw & Sage is supported and how product recommendations are handled.',
  path: '/disclosure',
  about: 'Affiliate relationships, product recommendations, and editorial independence',
});
---

<BaseLayout title="Affiliate Disclosure" description="How paw and sage is supported." breadcrumbs={breadcrumbs} schema={[schema]}>
  <section class="page-header">
    <div class="container-narrow">
      <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Affiliate Disclosure' }]} />
      <span class="eyebrow">Legal</span>
      <h1>Affiliate Disclosure</h1>
    </div>
  </section>

  <section class="content-section">
    <div class="container-narrow prose">
      <p>
        paw and sage currently participates in the Amazon Associates Program. If additional affiliate
        programs are activated later, this page will be updated before those links are used on the site.
      </p>

      <h2>What this means</h2>
      <p>
        When you click on certain product links on this site and make a purchase, paw and sage may
        earn a small commission at no additional cost to you. These commissions help fund the time
        spent researching, writing, and maintaining the content on this site.
      </p>

      <h2>How we recommend products</h2>
      <p>
        We only recommend products we would use ourselves or have researched in depth. Editorial
        recommendations are made independently of any affiliate relationship - meaning we never
        feature a product solely because of commission rates, and we will sometimes recommend
        products that pay us nothing if they are the right fit.
      </p>

      <h2>Specific programs</h2>
      <p>
        <strong>Amazon Associates:</strong> As an Amazon Associate, paw and sage earns from
        qualifying purchases.
      </p>

      <h2>Your choices</h2>
      <p>
        You are never obligated to use the affiliate links on this site. You can search for any
        recommended product directly on the retailer's website. Either way, the recommendation
        stands.
      </p>

      <p class="updated">
        Last updated: April 2026
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { padding: 3rem 0 2rem; text-align: center; }
  .page-header .eyebrow { display: block; margin-bottom: 1rem; }
  .content-section { padding: 2rem 0 5rem; }
  .prose { font-size: 1.05rem; line-height: 1.75; }
  .updated {
    margin-top: 3rem;
    font-size: 0.85rem;
    color: var(--ink-soft);
    font-style: italic;
  }
</style>
