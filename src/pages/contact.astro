---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { buildContactPageSchema } from '../lib/schema';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path: '/contact' },
];
const schema = buildContactPageSchema('Contact Paw & Sage', 'Get in touch with Paw & Sage.', '/contact');
---

<BaseLayout
  title="Contact"
  description="Get in touch with paw and sage."
  breadcrumbs={breadcrumbs}
  schema={schema}
>
  <section class="page-header">
    <div class="container-narrow">
      <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Contact' }]} />
      <span class="eyebrow">Contact</span>
      <h1>Say hello.</h1>
      <p class="lede">Questions, feedback, or a story about your cat are all welcome.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="container-narrow">
      <div class="contact-card">
        <h2>Email</h2>
        <p><a href="mailto:hello@pawandsage.com">hello@pawandsage.com</a></p>
        <p class="note">I read every email. Replies usually come within a few days, sometimes longer.</p>
      </div>

      <div class="contact-card">
        <h2>Pinterest</h2>
        <p><a href="https://pinterest.com/pawandsage" target="_blank" rel="noopener">@pawandsage on Pinterest</a></p>
      </div>

      <div class="contact-card">
        <h2>Brand & affiliate inquiries</h2>
        <p>For partnership requests, please email with "Partnership" in the subject line. We're selective and only consider products we'd genuinely use ourselves.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { padding: 5rem 0 2rem; text-align: center; }
  .page-header .eyebrow { display: block; margin-bottom: 1rem; }
  .lede {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin: 1rem auto 0;
  }
  .content-section { padding: 2rem 0 5rem; }
  .contact-card {
    padding: 2rem 0;
    border-bottom: 1px solid var(--line);
  }
  .contact-card:last-of-type { border-bottom: none; }
  .contact-card h2 {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
  }
  .contact-card p {
    margin: 0.25rem 0;
    color: var(--ink-soft);
  }
  .note {
    font-size: 0.85rem;
    font-style: italic;
    margin-top: 0.5rem;
  }
</style>
