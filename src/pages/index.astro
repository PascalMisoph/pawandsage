---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
import PostCard from '../components/PostCard.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { getCollection } from 'astro:content';
import responsiveImageManifest from '../generated/responsive-image-manifest.json';
import { PERSON, SITE_URL } from '../lib/site';
import { buildFAQPageSchema, buildPageSchema } from '../lib/schema';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
const homeFaq = [
  {
    question: 'What kind of cat advice does Paw & Sage cover?',
    answer:
      'Paw & Sage focuses on cat behavior, indoor enrichment, and the first weeks with a new cat, with an emphasis on practical routines that work in real homes.',
  },
  {
    question: 'Who writes Paw & Sage?',
    answer:
      'The site is written and edited by Pascal Misoph, with articles shaped by published feline welfare guidance, veterinary behavior resources, and careful product research where relevant.',
  },
  {
    question: 'Where should I start if I am new here?',
    answer:
      'Start with the journal if you want the latest articles, or go straight to Start Here if you want the best first reads for behavior, enrichment, and new cat care.',
  },
];
const updatedDate = '2026-04-24';
const heroEntry = responsiveImageManifest['/home-header-premium-wide.png'];
const heroJpegVariants = heroEntry.variants.jpeg;
const heroPreloadSrcset = heroJpegVariants.map((variant) => `${variant.src} ${variant.width}w`).join(', ');
const heroPreloadHref = heroJpegVariants[heroJpegVariants.length - 1]?.src ?? '/home-header-premium-wide.png';
const schema = [
  buildPageSchema({
    name: 'Paw & Sage',
    description: 'Calm, considered writing on cat behavior, indoor enrichment, and new cat care.',
    path: '/',
    image: '/home-header-premium-wide.png',
    about: 'Cat behavior, indoor enrichment, and new cat care',
    significantLinks: ['/blog', '/start-here', '/categories/behavior', '/categories/enrichment', '/categories/new-cat'],
  }),
  buildFAQPageSchema(homeFaq),
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: PERSON.name,
    url: PERSON.url,
    description: PERSON.description,
    jobTitle: PERSON.jobTitle,
    worksFor: {
      '@type': 'Organization',
      name: 'Paw & Sage',
      url: SITE_URL,
    },
  },
];
---

<BaseLayout
  title="paw and sage"
  description="Calm, considered writing on cat behavior, indoor enrichment, and new cat care."
  image="/home-header-premium-wide.png"
  breadcrumbs={[{ name: 'Home', path: '/' }]}
  schema={schema}
  resourceHints={[
    { rel: 'dns-prefetch', href: '//pawandsage.com' },
    { rel: 'preconnect', href: SITE_URL, crossorigin: 'anonymous' },
    {
      rel: 'preload',
      href: heroPreloadHref,
      as: 'image',
      imagesrcset: heroPreloadSrcset,
      imagesizes: '100vw',
      type: 'image/jpeg',
    },
  ]}
>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">A journal for thoughtful cat people</span>
        <h1 class="hero-title">
          Understand the cat <span class="italic">in your home.</span>
        </h1>
        <p class="hero-tagline">
          Calm, considered writing on cat behavior, indoor enrichment, and the small daily decisions that make life better for the cat and the human.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn btn-primary">Read the journal</a>
          <a href="/start-here" class="btn btn-outline">New here? Start here</a>
        </div>
        <p class="hero-note">
          Warm, research-aware guidance for the quiet cues that shape a richer indoor life.
        </p>
      </div>

      <figure class="hero-visual-wrap">
        <ResponsiveImage
          src="/home-header-premium-wide.png"
          alt="A wide sunlit home interior with a cat seated by a window in a calm editorial setting."
          sizes="100vw"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          pictureClass="hero-visual-picture"
          imgClass="hero-visual"
        />
      </figure>
    </div>
  </section>

  <section class="categories-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Three threads</span>
        <h2>Where to begin.</h2>
      </div>
      <div class="categories-grid">
        <a href="/categories/behavior" class="category-card">
          <h3>Behavior</h3>
          <p>What your cat is actually telling you, and how to listen.</p>
        </a>
        <a href="/categories/enrichment" class="category-card">
          <h3>Enrichment</h3>
          <p>Small changes that turn a flat indoor life into a rich one.</p>
        </a>
        <a href="/categories/new-cat" class="category-card">
          <h3>New Cat</h3>
          <p>Everything you wish someone had told you in the first week.</p>
        </a>
      </div>
    </div>
  </section>

  {sortedPosts.length > 0 && (
    <section class="recent-posts">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Latest from the journal</span>
          <h2>Recent reading.</h2>
        </div>
        <div class="posts-grid">
          {sortedPosts.map((post) => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              readTime={post.data.readTime}
              image={post.data.heroImage}
              imageAlt={post.data.heroAlt}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="trust-section">
    <div class="container trust-grid">
      <div class="trust-copy">
        <span class="eyebrow">Why trust this journal</span>
        <h2>Clear guidance, visible sources, and real editorial standards.</h2>
        <p>
          Paw & Sage is written and edited by <a href="/about">Pascal Misoph</a> and built around published feline welfare guidance, veterinary behavior resources, and practical home routines that are actually usable.
        </p>
        <p class="trust-meta">
          Updated {updatedDate} · Read the <a href="/editorial-policy">editorial policy</a>
        </p>
      </div>
      <div class="trust-sources">
        <h3>Sources that shape the site</h3>
        <ul>
          <li><a href="https://catvets.com/" target="_blank" rel="noopener noreferrer">Feline Veterinary Medical Association</a></li>
          <li><a href="https://catfriendly.com/" target="_blank" rel="noopener noreferrer">Cat Friendly Homes</a></li>
          <li><a href="/about">Author profile and publishing context</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="faq-section" aria-labelledby="home-faq-title">
    <div class="container-narrow">
      <span class="eyebrow">FAQ</span>
      <h2 id="home-faq-title">Common questions about Paw & Sage.</h2>
      <div class="faq-list">
        {homeFaq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="email-section">
    <div class="container-narrow">
      <EmailCapture />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: clamp(44rem, 100vh, 58rem);
    padding: 0;
    background:
      radial-gradient(circle at top left, rgba(221, 228, 216, 0.7), transparent 34%),
      linear-gradient(180deg, var(--cream-100) 0%, #f6efe3 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: -6rem auto auto 52%;
    width: min(38vw, 560px);
    aspect-ratio: 1;
    background: radial-gradient(circle, rgba(224, 160, 133, 0.22) 0%, transparent 72%);
    opacity: 0.9;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto auto -6rem -6rem;
    width: 24rem;
    height: 24rem;
    background: radial-gradient(circle, rgba(221, 228, 216, 0.85) 0%, transparent 72%);
    opacity: 0.85;
    pointer-events: none;
  }

  .hero-grid {
    min-height: inherit;
    padding-right: 1.5rem;
    padding-left: max(1.5rem, calc((100vw - var(--container)) / 2 + 1.5rem));
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 31rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: inherit;
    width: min(31rem, calc(100vw - 3rem));
    padding: clamp(7rem, 10vw, 9rem) 0 clamp(3rem, 6vw, 4.5rem);
    position: relative;
    z-index: 2;
  }

  .hero .eyebrow {
    display: block;
    margin-bottom: 1.25rem;
  }

  .hero-title {
    margin-bottom: 1.25rem;
    max-width: 10.5ch;
    font-size: clamp(3.25rem, 7vw, 5.3rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .hero-title .italic {
    color: var(--terra-500);
  }

  .hero-tagline {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.1rem, 2vw, 1.34rem);
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 29rem;
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.4rem;
  }

  .hero-note {
    width: fit-content;
    max-width: 29rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(90, 84, 78, 0.14);
    color: var(--sage-700);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    line-height: 1.6;
    text-transform: uppercase;
    margin: 0;
  }

  .hero-visual-wrap {
    margin: 0;
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .hero-visual-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(246, 239, 227, 0.985) 0%,
      rgba(246, 239, 227, 0.96) 16%,
      rgba(246, 239, 227, 0.9) 24%,
      rgba(246, 239, 227, 0.72) 33%,
      rgba(246, 239, 227, 0.42) 43%,
      rgba(246, 239, 227, 0.14) 54%,
      rgba(246, 239, 227, 0.03) 62%,
      transparent 72%
    );
    pointer-events: none;
    z-index: 1;
  }

  .hero-visual-wrap::after {
    content: '';
    position: absolute;
    inset: auto auto 1.5rem 1rem;
    width: 38%;
    height: 12%;
    border-radius: 999px;
    background: rgba(184, 197, 177, 0.34);
    filter: blur(34px);
    pointer-events: none;
  }

  .hero-visual-wrap :global(.hero-visual-picture) {
    width: 100%;
    height: 100%;
  }

  .hero-visual-wrap :global(.hero-visual) {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    background: #efe5d8;
    object-fit: cover;
    object-position: 60% center;
  }

  .categories-section {
    padding: 4rem 0 2.75rem;
  }

  .recent-posts {
    padding: 2.75rem 0 3.5rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.25rem;
  }

  .section-header .eyebrow {
    display: block;
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    margin: 0;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .category-card {
    padding: 2rem 1.5rem;
    background: var(--cream-200);
    border-radius: 8px;
    text-decoration: none;
    color: var(--ink);
    transition: all 0.2s ease;
    text-align: center;
    border: 1px solid transparent;
  }

  .category-card:hover {
    background: var(--sage-50);
    border-color: var(--sage-300);
    transform: translateY(-2px);
    color: var(--ink);
  }

  .category-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }

  .category-card p {
    color: var(--ink-soft);
    font-size: 0.85rem;
    margin: 0;
    line-height: 1.5;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .trust-section,
  .faq-section {
    padding: 0 0 3.25rem;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.5rem;
  }

  .trust-copy,
  .trust-sources,
  .faq-list details {
    background: var(--cream-200);
    border: 1px solid var(--line);
    border-radius: 12px;
  }

  .trust-copy,
  .trust-sources {
    padding: 2rem;
  }

  .trust-copy h2,
  .trust-sources h3 {
    margin-top: 0;
  }

  .trust-copy h2 {
    margin-bottom: 0.9rem;
  }

  .trust-copy p:last-child,
  .trust-sources ul {
    margin-bottom: 0;
  }

  .trust-copy p + p {
    margin-top: 0.9rem;
  }

  .trust-meta {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .trust-sources ul {
    padding-left: 1.1rem;
  }

  .faq-list {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .faq-list details {
    padding: 1rem 1.125rem;
  }

  .faq-list summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--sage-900);
  }

  .faq-list p {
    margin: 0.75rem 0 0;
    color: var(--ink-soft);
  }

  .email-section {
    padding: 0.75rem 0 2.5rem;
  }

  .email-section :global(.email-capture) {
    margin: 0;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: clamp(40rem, 100svh, 52rem);
      padding: 0;
    }

    .hero-grid {
      min-height: inherit;
      padding-right: 1.25rem;
      padding-left: 1.25rem;
    }

    .hero-copy {
      max-width: 100%;
      width: min(28rem, calc(100vw - 2.5rem));
      text-align: left;
      padding: clamp(6.75rem, 18vw, 8rem) 0 2.75rem;
      min-height: inherit;
    }

    .hero-title,
    .hero-tagline,
    .hero-note {
      margin-left: 0;
      margin-right: 0;
    }

    .hero-actions {
      justify-content: flex-start;
    }

    .hero-note {
      width: fit-content;
    }

    .hero-visual-wrap {
      position: absolute;
      inset: 0;
      min-height: inherit;
      border-radius: 0;
      margin-top: 0;
      z-index: 0;
    }

    .hero-visual-wrap::before {
      background: linear-gradient(
        180deg,
        rgba(246, 239, 227, 0.48) 0%,
        rgba(246, 239, 227, 0.16) 18%,
        rgba(246, 239, 227, 0.92) 100%
      ),
      linear-gradient(
        90deg,
        rgba(246, 239, 227, 0.99) 0%,
        rgba(246, 239, 227, 0.95) 28%,
        rgba(246, 239, 227, 0.75) 46%,
        rgba(246, 239, 227, 0.32) 62%,
        rgba(246, 239, 227, 0.08) 76%,
        transparent 92%
      );
    }

    .hero-visual-wrap :global(.hero-visual) {
      min-height: inherit;
      height: 100%;
      border-radius: 0;
      object-position: 68% center;
    }

    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .trust-grid {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }

    .categories-section {
      padding: 3.5rem 0 2.25rem;
    }

    .recent-posts {
      padding: 2.25rem 0 3rem;
    }

    .trust-section,
    .faq-section {
      padding: 0 0 2.75rem;
    }

    .email-section {
      padding: 0.5rem 0 2.25rem;
    }

    .trust-copy,
    .trust-sources {
      padding: 1.5rem;
    }

    .trust-copy h2 {
      font-size: 1.7rem;
      line-height: 1.08;
    }

    .trust-sources h3 {
      font-size: 1.25rem;
      margin-bottom: 0.85rem;
    }

    .faq-list details {
      padding: 1rem;
    }
  }

  @media (max-width: 600px) {
    .hero {
      min-height: 38rem;
    }

    .hero-grid {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .hero-copy {
      width: min(24rem, calc(100vw - 2rem));
      padding-top: 6.25rem;
      padding-bottom: 2.5rem;
    }

    .hero-visual-wrap :global(.hero-visual) {
      object-position: 71% center;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      margin-bottom: 1.75rem;
    }

    .categories-section {
      padding: 3rem 0 2rem;
    }

    .recent-posts {
      padding: 2rem 0 2.5rem;
    }

    .trust-section,
    .faq-section {
      padding: 0 0 2.25rem;
    }

    .email-section {
      padding: 0.25rem 0 2rem;
    }

    .trust-section {
      padding-bottom: 2.5rem;
    }

    .faq-section {
      padding-bottom: 2.5rem;
    }

    .trust-grid {
      gap: 0.9rem;
    }

    .trust-copy,
    .trust-sources {
      padding: 1.25rem;
      border-radius: 10px;
    }

    .trust-copy h2 {
      font-size: 1.45rem;
      line-height: 1.12;
      margin-bottom: 0.8rem;
    }

    .trust-copy p {
      font-size: 0.97rem;
      line-height: 1.65;
    }

    .trust-meta {
      font-size: 0.88rem;
    }

    .trust-sources h3 {
      font-size: 1.1rem;
      margin-bottom: 0.75rem;
    }

    .trust-sources ul {
      padding-left: 1rem;
    }

    .faq-list {
      gap: 0.85rem;
    }

    .faq-list details {
      padding: 0.95rem 0.95rem 1rem;
      border-radius: 10px;
    }

    .faq-list summary {
      font-size: 0.98rem;
      line-height: 1.45;
    }

    .faq-list p {
      font-size: 0.95rem;
      line-height: 1.62;
    }
  }

  .faq-list summary {
    list-style: none;
  }

  .faq-list summary::marker {
    content: '';
  }

  .faq-list summary::-webkit-details-marker {
    display: none;
  }
</style>
