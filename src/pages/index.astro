---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title="paw and sage" image="/home-header-premium-wide.png">
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">A journal for thoughtful cat people</span>
        <h1 class="hero-title">
          Understand the cat <span class="italic">in your home.</span>
        </h1>
        <p class="hero-tagline">
          Calm, considered writing on cat behavior, indoor enrichment, and the small daily decisions that make life better for the cat and the human.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn btn-primary">Read the journal</a>
          <a href="/start-here" class="btn btn-outline">New here? Start here</a>
        </div>
        <p class="hero-note">
          Warm, science-informed guidance for the quiet cues that shape a richer indoor life.
        </p>
      </div>

      <figure class="hero-visual-wrap">
        <img
          class="hero-visual"
          src="/home-header-premium-wide.png"
          alt="A wide sunlit home interior with a cat seated by a window in a calm editorial setting."
          width="1600"
          height="1000"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </figure>
    </div>
  </section>

  <section class="categories-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Four threads</span>
        <h2>Where to begin.</h2>
      </div>
      <div class="categories-grid">
        <a href="/categories/behavior" class="category-card">
          <h3>Behavior</h3>
          <p>What your cat is actually telling you, and how to listen.</p>
        </a>
        <a href="/categories/enrichment" class="category-card">
          <h3>Enrichment</h3>
          <p>Small changes that turn a flat indoor life into a rich one.</p>
        </a>
        <a href="/categories/new-cat" class="category-card">
          <h3>New Cat</h3>
          <p>Everything you wish someone had told you in the first week.</p>
        </a>
        <a href="/categories/health" class="category-card">
          <h3>Health</h3>
          <p>The subtle signals worth noticing, and when to call the vet.</p>
        </a>
      </div>
    </div>
  </section>

  {sortedPosts.length > 0 && (
    <section class="recent-posts">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Latest from the journal</span>
          <h2>Recent reading.</h2>
        </div>
        <div class="posts-grid">
          {sortedPosts.map((post) => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              readTime={post.data.readTime}
              image={post.data.heroImage}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="email-section">
    <div class="container-narrow">
      <EmailCapture />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: clamp(44rem, 100vh, 58rem);
    padding: 0;
    background:
      radial-gradient(circle at top left, rgba(221, 228, 216, 0.7), transparent 34%),
      linear-gradient(180deg, var(--cream-100) 0%, #f6efe3 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: -6rem auto auto 52%;
    width: min(38vw, 560px);
    aspect-ratio: 1;
    background: radial-gradient(circle, rgba(224, 160, 133, 0.22) 0%, transparent 72%);
    opacity: 0.9;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto auto -6rem -6rem;
    width: 24rem;
    height: 24rem;
    background: radial-gradient(circle, rgba(221, 228, 216, 0.85) 0%, transparent 72%);
    opacity: 0.85;
    pointer-events: none;
  }

  .hero-grid {
    min-height: inherit;
    padding-right: 1.5rem;
    padding-left: max(1.5rem, calc((100vw - var(--container)) / 2 + 1.5rem));
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 31rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: inherit;
    width: min(31rem, calc(100vw - 3rem));
    padding: clamp(7rem, 10vw, 9rem) 0 clamp(3rem, 6vw, 4.5rem);
    position: relative;
    z-index: 2;
  }

  .hero .eyebrow {
    display: block;
    margin-bottom: 1.25rem;
  }

  .hero-title {
    margin-bottom: 1.25rem;
    max-width: 10.5ch;
    font-size: clamp(3.25rem, 7vw, 5.3rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .hero-title .italic {
    color: var(--terra-500);
  }

  .hero-tagline {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.1rem, 2vw, 1.34rem);
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 29rem;
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.4rem;
  }

  .hero-note {
    width: fit-content;
    max-width: 29rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(90, 84, 78, 0.14);
    color: var(--sage-700);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    line-height: 1.6;
    text-transform: uppercase;
    margin: 0;
  }

  .hero-visual-wrap {
    margin: 0;
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .hero-visual-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(246, 239, 227, 0.985) 0%,
      rgba(246, 239, 227, 0.96) 16%,
      rgba(246, 239, 227, 0.9) 24%,
      rgba(246, 239, 227, 0.72) 33%,
      rgba(246, 239, 227, 0.42) 43%,
      rgba(246, 239, 227, 0.14) 54%,
      rgba(246, 239, 227, 0.03) 62%,
      transparent 72%
    );
    pointer-events: none;
    z-index: 1;
  }

  .hero-visual-wrap::after {
    content: '';
    position: absolute;
    inset: auto auto 1.5rem 1rem;
    width: 38%;
    height: 12%;
    border-radius: 999px;
    background: rgba(184, 197, 177, 0.34);
    filter: blur(34px);
    pointer-events: none;
  }

  .hero-visual {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    background: #efe5d8;
    object-fit: cover;
    object-position: 60% center;
  }

  .categories-section,
  .recent-posts {
    padding: 5rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header .eyebrow {
    display: block;
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    margin: 0;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .category-card {
    padding: 2rem 1.5rem;
    background: var(--cream-200);
    border-radius: 8px;
    text-decoration: none;
    color: var(--ink);
    transition: all 0.2s ease;
    text-align: center;
    border: 1px solid transparent;
  }

  .category-card:hover {
    background: var(--sage-50);
    border-color: var(--sage-300);
    transform: translateY(-2px);
    color: var(--ink);
  }

  .category-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }

  .category-card p {
    color: var(--ink-soft);
    font-size: 0.85rem;
    margin: 0;
    line-height: 1.5;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .email-section {
    padding: 3rem 0 5rem;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
      padding-top: 3.25rem;
      padding-bottom: 3rem;
    }

    .hero-grid {
      min-height: auto;
      padding-right: 1.25rem;
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .hero-copy {
      max-width: 100%;
      width: 100%;
      text-align: center;
      padding: 0;
      min-height: auto;
    }

    .hero-title,
    .hero-tagline,
    .hero-note {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-note {
      width: 100%;
    }

    .hero-visual-wrap {
      min-height: auto;
      position: relative;
      inset: auto;
      border-radius: 1.8rem;
      margin-top: 2rem;
      z-index: auto;
    }

    .hero-visual {
      min-height: clamp(24rem, 60vw, 34rem);
      height: auto;
      border-radius: inherit;
      object-position: 64% center;
    }

    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding-top: 2.75rem;
    }

    .hero-grid {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .hero-visual {
      min-height: 22rem;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
